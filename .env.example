# Next.js Frontend — Kelova
# Copy to .env.local for local development

# API
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# Auth — Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# App domain (used by middleware for subdomain tenant resolution)
# NOTE: domain purchase not finalized yet (see REBRAND.md decision #1) — kelova.com
# is the working assumption used elsewhere in the codebase, not a confirmed purchase.
NEXT_PUBLIC_APP_DOMAIN=kelova.com

# PWA (set true in Phase 2 to activate service worker)
NEXT_PUBLIC_ENABLE_PWA=false
